rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@versantapp.com';
    }

    // Helper function to check if user is owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      // Admin can read all users (for Dashboard list)
      allow list: if isAdmin();
      // Owner or Admin can get specific user Doc
      allow get: if isOwner(userId) || isAdmin();
      
      // Admin can create/update anyone. Owner can create self but cannot set hasPaid to true.
      allow create: if isAdmin() || (isOwner(userId) && (!('hasPaid' in request.resource.data) || request.resource.data.hasPaid == false));
      // Owner can update self, but CANNOT modify the hasPaid lock. Only Admin/Backend can modify hasPaid.
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['hasPaid']));
      allow delete: if isAdmin();

      // Subcollection: Test Results
      match /testResults/{resultId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }
    
    // NEW: Analytics Events Collection
    match /analytics_events/{eventId} {
      // Anyone (including anonymous guests) can ping an activity event
      allow create: if true;
      // Only the True Admin can read the live feed or flush the database
      allow read, delete: if isAdmin();
      allow update: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
